{
  "name": "soroban-escrow-dashboard",
  "version": "0.1.0",
  "private": true,
  "description": "An intuitive dashboard for monitoring a specified Soroban escrow smart contract, visualizing historical data, real-time events and transactions.",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "format": "prettier --write ./**/*",
    "format:check": "prettier --check ./**/*",
    "migrate": "NODE_OPTIONS='--loader ts-node/esm' ts-node ./lib/database/migrate.ts",
    "migrate:down": "MIGRATE_OPTION=down NODE_OPTIONS='--loader ts-node/esm' ts-node ./lib/database/migrate.ts",
    "migrate:list": "MIGRATE_OPTION=list NODE_OPTIONS='--loader ts-node/esm' ts-node ./lib/database/migrate.ts",
    "generate-schema": "kysely-codegen --dialect postgres --out-file ./lib/database/schema.ts"
  },
  "author": "Padparadscho <contact@padparadscho.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/padparadscho/soroban-escrow-dashboard.git"
  },
  "bugs": "https://github.com/padparadscho/soroban-escrow-dashboard/issues",
  "homepage": "https://github.com/padparadscho/soroban-escrow-dashboard#readme",
  "license": "GPL-3.0-only",
  "dependencies": {
    "chart.js": "4.5.1",
    "chartjs-adapter-date-fns": "3.0.0",
    "date-fns": "4.1.0",
    "dotenv": "17.4.0",
    "kysely": "0.28.15",
    "motion": "12.38.0",
    "next": "16.2.3",
    "pg": "8.20.0",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "4.2.0",
    "@types/node": "25.5.0",
    "@types/pg": "8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.3",
    "eslint-config-prettier": "10.1.8",
    "kysely-codegen": "0.20.0",
    "prettier": "3.8.2",
    "tailwindcss": "4.2.0",
    "ts-node": "10.9.2",
    "typescript": "6.0.2"
  },
  "packageManager": "pnpm@10.33.0"
}
